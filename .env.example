# K8s OS Monitor 환경 변수 예시
# 이 파일을 .env 로 복사하여 실제 값으로 채우세요.
# 주의: .env 파일과 실제 시크릿 값은 절대 git에 커밋하지 마세요.
# K8s 환경에서는 secretKeyRef 로 주입합니다.

# TimescaleDB 연결 (형식: postgresql://user:pass@host:port/dbname)
DATABASE_URL=postgresql://monitor:CHANGE_ME@timescaledb.monitoring.svc:5432/monitor

# API 인증 키
API_KEY=CHANGE_ME

# CORS 허용 오리진 (쉼표 구분)
CORS_ORIGINS=http://localhost:3000,https://your-dashboard.example.com

# Prometheus URL (클러스터 내부)
PROMETHEUS_URL=http://prometheus-stack-kube-prom-prometheus.monitoring:9090

# Loki URL (클러스터 내부)
LOKI_URL=http://loki-stack.logging:3100

# 리포트 저장 경로
REPORT_OUTPUT_DIR=/data/reports

# SSH 수집 사용자 (선택 — 미설정 시 SSH 수집 비활성화)
# SSH_USER=monitor
# SSH_KEY_PATH=/home/monitor/.ssh/id_rsa

# 로그 레벨
LOG_LEVEL=INFO
